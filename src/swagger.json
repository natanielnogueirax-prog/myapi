                      },
                      "name": {
                        "type": "string"
                      },
                      "created_at": {
                        "type": "string"
                      }
                    }
                  },
                  "example": {
                    "id": "a2f4n2h343h4",
                    "name": "Administrator",
                    "created_at": "2026-01-01 18:45:00"
                  }
                }
              }
            },
            "400": {
              "description": "Bad request."
            },
            "404": {
              "description": "Role not found."
            }
          }
      }
