  "paths": {
    "/roles": {
      "post": {
        "tags": ["Roles"],
        "sumarry": "Create a role",
        "description": "Create a new role",
        "requestBody": {
          "content": {
            "application/json":{
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Role created!",
            "content": {
              "application/json":{
                "schema":{
                  "type":"object",
                  "properties":{
                    "id":{
                      "type":"string"
                    },
                    "name":{
                      "type":"string"
                    },
                    "created_at":{
                      "type":"string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Role already exists"
          }
        }
      },
      "get": {
        "tags": ["Roles"],
        "sumarry": "List all roles",
        "description": "return all roles paginated",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Number of the page",
            "required": false,
            "schema": {
              "type": "number",
              "example": "page=1"
            },
            "style": "label"
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of registers per page",
            "required": false,
            "schema": {
              "type": "number",
              "example": "limit=15"
            },
            "style": "label"
          }
        ],
          "responses": {
            "200": {
              "description": "success.",
              "content": {
                "application/json": {
                  "example": {
                    "per_page": 15,
                    "total": 2,
                    "current_page": 1,
                    "data": [
                      {
                        "id": "a2f4n2h343h4",
                        "name": "users",
                        "created_at": "2026-01-01 18:45:00"
                      },
                      {
                        "id": "a2f4n2h343hdsf4",
                        "name": "usuarios",
                        "created_at": "2026-01-08 18:45:00"
                      }
                    ]
                  }
                }
              }
            }
          }
      }
    },
    "/roles/{id}": {
      "put": {
        "tags": ["Roles"],
        "sumarry": "Update a role",
        "description": "Update a role",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Identify of a role",
            "required": true,
            "schema": {
              "type": "string"
            },
            "style": "label"
          }
        ],
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": "string"
                  }
                },
                "example": "Administrator"
              }
            }
          },
          "responses": {
            "200": {
              "description": "success.",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "created_at": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Bad request."
            },
            "404": {
              "description": "Role not found."
            }
          }
      },
      "get": {
        "tags": ["Roles"],
        "sumarry": "Find roles by  id",
        "description": "Return roles based on id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Identify of a role",
            "required": true,
            "schema": {
              "type": "string"
            },
            "style": "label"
