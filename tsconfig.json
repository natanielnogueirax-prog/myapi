{
  "compilerOptions": {
    "target": "ES2022",

    "module": "CommonJS",
    "moduleResolution": "node",

    "rootDir": "./src",
    "outDir": "./dist",

    "baseUrl": ".",

    "paths": {
      "@roles/*": ["src/roles/*"],
      "@users/*": ["src/users/*"],
      "@shared/*": ["src/shared/*"]
    },

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "sourceMap": true,
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
